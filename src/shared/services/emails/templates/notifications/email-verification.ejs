<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Verify Your Email</title>
    <style>
      body {
        margin: 0;
        padding: 0;
        background-color: #f0f2f5;
        font-family: "Helvetica Neue", Helvetica, Arial, sans-serif;
        -webkit-font-smoothing: antialiased;
      }
      .wrapper {
        width: 100%;
        table-layout: fixed;
        background-color: #f0f2f5;
        padding: 40px 0;
      }
      .main {
        background-color: #ffffff;
        margin: 0 auto;
        width: 100%;
        max-width: 550px;
        border-spacing: 0;
        color: #1c1e21;
        border-radius: 24px;
        overflow: hidden;
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.08);
      }
      .header {
        background: linear-gradient(135deg, #10b981 0%, #059669 100%);
        padding: 50px 40px;
        text-align: center;
      }
      .header h2 {
        color: #ffffff;
        margin: 0;
        font-size: 30px;
        font-weight: 800;
        letter-spacing: -0.5px;
      }
      .hero-img-container {
        width: 100%;
        text-align: center;
        background-color: #ffffff;
      }
      .content {
        padding: 40px 40px 30px;
        text-align: left;
      }
      .content h3 {
        font-size: 24px;
        margin-top: 0;
        color: #059669;
        font-weight: 700;
      }
      .content p {
        font-size: 16px;
        line-height: 1.6;
        margin: 0 0 24px;
        color: #4b5563;
      }
      .btn-container {
        padding: 10px 0 35px;
        text-align: center;
      }
      .button {
        background-color: #10b981;
        color: #ffffff !important;
        padding: 18px 45px;
        text-decoration: none;
        border-radius: 14px;
        font-weight: 700;
        font-size: 17px;
        display: inline-block;
        box-shadow: 0 10px 20px rgba(16, 185, 129, 0.2);
      }
      .link-desc {
        font-size: 13px;
        color: #9ca3af;
        text-align: center;
        padding: 0 40px 35px;
        line-height: 1.5;
      }
      .link-desc a {
        color: #10b981;
        word-break: break-all;
        text-decoration: none;
      }
      .divider {
        height: 1px;
        background-color: #f3f4f6;
        margin: 0 40px;
      }
      .footer {
        padding: 35px 40px;
        text-align: center;
        font-size: 13px;
        color: #9ca3af;
        background-color: #fafafa;
      }
    </style>
  </head>
  <body>
    <div class="wrapper">
      <table class="main" cellpadding="0" cellspacing="0">
        <tr>
          <td class="header">
            <h2>Welcome to Chatty! 🚀</h2>
          </td>
        </tr>
        <tr>
          <td class="content">
            <h3>Confirm your account</h3>
            <p>Hi <strong><%= username %></strong>,</p>
            <p>
              We're thrilled to have you join our community! To start exploring
              and connecting with friends, please verify your email address by
              clicking the button below:
            </p>
          </td>
        </tr>
        <tr>
          <td class="btn-container">
            <a href="<%= verificationLink %>" class="button"
              >Verify Email Address</a
            >
          </td>
        </tr>
        <tr>
          <td class="link-desc">
            <p>
              If the button above doesn't work, you can also copy and paste this
              link into your browser:
            </p>
            <a href="<%= verificationLink %>"><%= verificationLink %></a>
          </td>
        </tr>
        <tr>
          <td>
            <div class="divider"></div>
          </td>
        </tr>
        <tr>
          <td class="footer">
            <p>
              You received this email because you signed up for a Chatty
              account.
            </p>
            <p>&copy; 2026 Chatty Inc. All rights reserved.</p>
          </td>
        </tr>
      </table>
    </div>
  </body>
</html>
