<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <style>
      body {
        margin: 0;
        padding: 0;
        font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
        background-color: #f4f7f6;
        color: #333;
      }
      .email-wrapper {
        width: 100%;
        background-color: #f4f7f6;
        padding: 20px 0;
      }
      .email-container {
        max-width: 600px;
        margin: 0 auto;
        background-color: #ffffff;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05);
      }
      .header {
        background: linear-gradient(135deg, #10b981 0%, #059669 100%);
        padding: 30px;
        text-align: center;
        color: #ffffff;
      }
      .header h1 {
        margin: 0;
        font-size: 28px;
        font-weight: 700;
        letter-spacing: 1px;
      }
      .hero-img-container {
        padding: 20px;
        text-align: center;
        background-color: #ffffff;
      }
      .content {
        padding: 40px 40px 30px;
        text-align: left;
      }
      .content h3 {
        color: #111827;
        font-size: 22px;
        margin-top: 0;
        margin-bottom: 20px;
      }
      .content p {
        font-size: 16px;
        line-height: 1.6;
        color: #4b5563;
        margin-bottom: 25px;
      }
      .info-box {
        background-color: #f9fafb;
        border-radius: 12px;
        padding: 20px;
        margin-bottom: 30px;
        border: 1px solid #f3f4f6;
      }
      .info-item {
        margin-bottom: 10px;
        font-size: 14px;
        color: #4b5563;
      }
      .info-item strong {
        color: #111827;
        width: 100px;
        display: inline-block;
      }
      .footer {
        padding: 30px;
        background-color: #fafafa;
        text-align: center;
        border-top: 1px solid #f3f4f6;
      }
      .footer p {
        font-size: 13px;
        color: #9ca3af;
        margin: 5px 0;
      }
      .social-links {
        margin-bottom: 20px;
      }
      .social-links img {
        margin: 0 8px;
        vertical-align: middle;
      }
      .success-icon {
        width: 64px;
        height: 64px;
        margin-bottom: 20px;
      }
    </style>
  </head>
  <body>
    <div class="email-wrapper">
      <div class="email-container">
        <div class="header">
          <h1>Chatty 🚀</h1>
        </div>

        <div class="content">
          <h3>Password Changed Successfully</h3>
          <p>Hi <strong><%= username %></strong>,</p>
          <p>
            Your account password has been successfully changed. You can now use
            your new password to sign in to Chatty.
          </p>

          <div class="info-box">
            <div class="info-item"><strong>Email:</strong> <%= email %></div>
            <div class="info-item"><strong>Date:</strong> <%= date %></div>
            <div class="info-item">
              <strong>IP Address:</strong> <%= ipaddress %>
            </div>
          </div>

          <p style="color: #ef4444; font-size: 14px; font-weight: 500">
            If you did not perform this action, please contact our support team
            immediately or try to reset your password again.
          </p>
        </div>

        <div class="footer">
          <p>&copy; 2026 Chatty Inc. All rights reserved.</p>
          <p>Vietnam</p>
        </div>
      </div>
    </div>
  </body>
</html>
